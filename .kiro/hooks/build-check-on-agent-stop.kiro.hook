{
  "enabled": true,
  "name": "Build Check on Agent Stop",
  "description": "Runs npm run build after every agent session to catch any build failures introduced by code changes",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "npm run build",
    "timeout": 120
  }
}